{
  "manifest_version": 3,
  "name": "Make Social Media Boring",
  "version": "1.3.2",
  "description": "Strip the dopamine from social media. Popularity becomes a negative signal across 21 platforms.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.reddit.com/*",
    "*://reddit.com/*",
    "*://*.x.com/*",
    "*://x.com/*",
    "*://*.twitter.com/*",
    "*://twitter.com/*",
    "*://*.youtube.com/*",
    "*://youtube.com/*",
    "*://youtu.be/*",
    "*://*.instagram.com/*",
    "*://instagram.com/*",
    "*://*.tiktok.com/*",
    "*://tiktok.com/*",
    "*://*.facebook.com/*",
    "*://facebook.com/*",
    "*://*.fb.com/*",
    "*://*.linkedin.com/*",
    "*://linkedin.com/*",
    "*://*.threads.net/*",
    "*://threads.net/*",
    "*://*.pinterest.com/*",
    "*://pinterest.com/*",
    "*://*.pinterest.co.uk/*",
    "*://*.pinterest.ca/*",
    "*://*.pinterest.de/*",
    "*://*.pinterest.fr/*",
    "*://*.pinterest.jp/*",
    "*://*.pinterest.com.au/*",
    "*://*.bsky.app/*",
    "*://bsky.app/*",
    "*://*.9gag.com/*",
    "*://9gag.com/*",
    "*://*.ifunny.co/*",
    "*://ifunny.co/*",
    "*://*.imgur.com/*",
    "*://imgur.com/*",
    "*://*.lemon8-app.com/*",
    "*://lemon8-app.com/*",
    "*://*.xiaohongshu.com/*",
    "*://xiaohongshu.com/*",
    "*://*.xhslink.com/*",
    "*://*.douyin.com/*",
    "*://douyin.com/*",
    "*://*.weibo.com/*",
    "*://weibo.com/*",
    "*://*.bilibili.com/*",
    "*://bilibili.com/*",
    "*://*.bilibili.tv/*",
    "*://*.vk.com/*",
    "*://vk.com/*",
    "*://*.vk.ru/*",
    "*://vk.ru/*",
    "*://*.tumblr.com/*",
    "*://tumblr.com/*",
    "*://*.flickr.com/*",
    "*://flickr.com/*"
  ],
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Make Social Media Boring",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.reddit.com/*",
        "*://reddit.com/*",
        "*://*.x.com/*",
        "*://x.com/*",
        "*://*.twitter.com/*",
        "*://twitter.com/*",
        "*://*.youtube.com/*",
        "*://youtube.com/*",
        "*://*.instagram.com/*",
        "*://instagram.com/*",
        "*://*.tiktok.com/*",
        "*://tiktok.com/*",
        "*://*.facebook.com/*",
        "*://facebook.com/*",
        "*://*.linkedin.com/*",
        "*://linkedin.com/*",
        "*://*.threads.net/*",
        "*://threads.net/*",
        "*://*.pinterest.com/*",
        "*://pinterest.com/*",
        "*://*.pinterest.co.uk/*",
        "*://*.pinterest.ca/*",
        "*://*.pinterest.de/*",
        "*://*.pinterest.fr/*",
        "*://*.pinterest.jp/*",
        "*://*.pinterest.com.au/*",
        "*://*.bsky.app/*",
        "*://bsky.app/*",
        "*://*.9gag.com/*",
        "*://9gag.com/*",
        "*://*.ifunny.co/*",
        "*://ifunny.co/*",
        "*://*.imgur.com/*",
        "*://imgur.com/*",
        "*://*.lemon8-app.com/*",
        "*://lemon8-app.com/*",
        "*://*.xiaohongshu.com/*",
        "*://xiaohongshu.com/*",
        "*://*.douyin.com/*",
        "*://douyin.com/*",
        "*://*.weibo.com/*",
        "*://weibo.com/*",
        "*://*.bilibili.com/*",
        "*://bilibili.com/*",
        "*://*.bilibili.tv/*",
        "*://*.vk.com/*",
        "*://vk.com/*",
        "*://*.vk.ru/*",
        "*://vk.ru/*",
        "*://*.tumblr.com/*",
        "*://tumblr.com/*",
        "*://*.flickr.com/*",
        "*://flickr.com/*"
      ],
      "js": ["dist/content.js"],
      "css": ["src/content/host.css", "src/content/platforms.css"],
      "run_at": "document_idle"
    }
  ]
}
